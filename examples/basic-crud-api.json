    {
        "id": "update-product-handler",
        "type": "function",
        "z": "basic-crud-flow",
        "name": "Handle Update Product",
        "func": "// Mock product database\nconst products = {\n    1: { id: 1, name: 'Widget A', price: 19.99, description: 'A basic widget' },\n    2: { id: 2, name: 'Widget B', price: 29.99, description: 'An advanced widget' },\n    3: { id: 3, name: 'Gadget X', price: 49.99, description: 'A premium gadget' },\n    4: { id: 4, name: 'Tool Y', price: 9.99, description: 'An essential tool' },\n    5: { id: 5, name: 'Device Z', price: 99.99, description: 'A smart device' }\n};\n\nconst productId = msg.req.params.id;\nconst product = products[productId];\n\nif (product) {\n    const body = msg.req.body;\n    const updatedProduct = {\n        ...product,\n        ...body,\n        id: product.id, // Ensure ID cannot be changed\n        updatedAt: new Date().toISOString()\n    };\n    \n    msg.res.json(updatedProduct);\n} else {\n    msg.res.status(404).json({\n        type: 'https://api.example.com/errors/not-found',\n        title: 'Product Not Found',\n        status: 404,\n        detail: `Product with ID ${productId} was not found`\n    });\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 420,
