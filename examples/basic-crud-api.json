        "id": "list-products-handler",
        "type": "function",
        "z": "basic-crud-flow",
        "name": "Handle List Products",
        "func": "// In a real application, this would query a database\n// For this example, we return mock data\n\nconst products = [\n    { id: 1, name: 'Widget A', price: 19.99, description: 'A basic widget' },\n    { id: 2, name: 'Widget B', price: 29.99, description: 'An advanced widget' },\n    { id: 3, name: 'Gadget X', price: 49.99, description: 'A premium gadget' },\n    { id: 4, name: 'Tool Y', price: 9.99, description: 'An essential tool' },\n    { id: 5, name: 'Device Z', price: 99.99, description: 'A smart device' }\n];\n\nconst query = msg.req.query || {};\nconst limit = parseInt(query.limit) || 10;\nconst offset = parseInt(query.offset) || 0;\n\nconst paginatedProducts = products.slice(offset, offset + limit);\n\nmsg.res.json({\n    data: paginatedProducts,\n    total: products.length,\n    limit: limit,\n    offset: offset\n});\n\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
