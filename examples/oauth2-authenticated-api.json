    },
    {
        "id": "oauth2-comment-4",
        "type": "comment",
        "z": "oauth2-auth-flow",
        "name": "Multiple Required Scopes",
        "info": "This endpoint requires BOTH 'admin' AND 'user:write' scopes.\nThe scopeOperator is set to 'AND'.\n\nCommonly used patterns:\n- Single role: 'user'\n- Multiple roles (AND): 'admin, user:write'\n- Multiple roles (OR): 'admin, moderator' with scopeOperator='OR'\n\nRate limiting is also enabled on this endpoint:\n- 10 requests per minute per user\n- Key type is 'user' (uses auth.sub from token)",
        "x": 190,
        "y": 460,
        "wires": []
