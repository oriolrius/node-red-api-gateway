        "id": "oauth2-comment-3",
        "type": "comment",
        "z": "oauth2-auth-flow",
        "name": "Protected Endpoints (Single Scope)",
        "info": "The 'requiredScopes' field specifies which scopes/roles\nare needed to access the endpoint.\n\nWith scopeOperator: 'AND', all listed scopes are required.\nWith scopeOperator: 'OR', any one scope is sufficient.",
        "x": 220,
        "y": 260,
