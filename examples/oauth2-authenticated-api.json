    {
        "id": "user-profile-handler",
        "type": "function",
        "z": "oauth2-auth-flow",
        "name": "Handle User Profile",
        "func": "// This endpoint requires the 'user' scope/role\n// The auth info is populated by the api-server's auth middleware\n\nconst auth = msg.req.auth;\n\nif (!auth || !auth.authenticated) {\n    // This shouldn't happen as the endpoint checks auth,\n    // but included for safety\n    msg.res.status(401).json({\n        statusCode: 401,\n        error: 'Unauthorized',\n        message: 'Authentication required'\n    });\n    return null;\n}\n\n// Return user profile from token claims\nmsg.res.json({\n    sub: auth.sub,\n    username: auth.preferredUsername || auth.payload.preferred_username,\n    email: auth.email || auth.payload.email,\n    roles: auth.roles || [],\n    scopes: auth.scopes || [],\n    // Additional claims from the token\n    name: auth.payload.name,\n    givenName: auth.payload.given_name,\n    familyName: auth.payload.family_name\n});\n\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 300,
        "wires": [[]]
