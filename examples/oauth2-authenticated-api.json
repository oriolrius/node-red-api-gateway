    {
        "id": "admin-list-users-handler",
        "type": "function",
        "z": "oauth2-auth-flow",
        "name": "Handle List Users (Admin)",
        "func": "// This endpoint requires the 'admin' role\n// Only administrators can list all users\n\nconst query = msg.req.query || {};\nconst page = parseInt(query.page) || 1;\nconst limit = parseInt(query.limit) || 20;\n\n// Mock user data - in production, query from database\nconst allUsers = [\n    { id: 'u1', username: 'john.doe', email: 'john@example.com', enabled: true },\n    { id: 'u2', username: 'jane.smith', email: 'jane@example.com', enabled: true },\n    { id: 'u3', username: 'bob.wilson', email: 'bob@example.com', enabled: false },\n    { id: 'u4', username: 'alice.jones', email: 'alice@example.com', enabled: true },\n    { id: 'u5', username: 'charlie.brown', email: 'charlie@example.com', enabled: true }\n];\n\nconst offset = (page - 1) * limit;\nconst users = allUsers.slice(offset, offset + limit);\n\nmsg.res.json({\n    users: users,\n    total: allUsers.length,\n    page: page,\n    limit: limit\n});\n\nreturn null;",
