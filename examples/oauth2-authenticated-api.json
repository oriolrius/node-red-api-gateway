    {
        "id": "admin-create-user-handler",
        "type": "function",
        "z": "oauth2-auth-flow",
        "name": "Handle Create User (Admin)",
        "func": "// This endpoint requires BOTH 'admin' AND 'user:write' scopes\n// Demonstrates the AND scope operator\n\nconst body = msg.req.body;\n\n// In production, this would:\n// 1. Hash the password\n// 2. Store in database\n// 3. Possibly create user in Keycloak\n\nconst newUser = {\n    id: 'u' + Math.random().toString(36).substr(2, 9),\n    username: body.username,\n    email: body.email,\n    roles: body.roles || ['user'],\n    createdAt: new Date().toISOString(),\n    createdBy: msg.req.auth.sub  // Track who created this user\n};\n\nmsg.res.status(201).json(newUser);\n\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
