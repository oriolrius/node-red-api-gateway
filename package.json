{
  "name": "@oriolrius/node-red-api-gateway",
  "version": "0.3.0",
  "description": "Node-RED nodes for API gateway functionality",
  "keywords": [
    "node-red"
  ],
  "author": {
    "name": "Oriol Rius",
    "email": "oriol@oriolrius.me"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oriol/node-red-api-gateway.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "mocha \"tests/unit/**/*_spec.js\" --exit",
    "test:watch": "mocha \"tests/unit/**/*_spec.js\" --watch",
    "lint": "eslint nodes/ tests/",
    "lint:fix": "eslint nodes/ tests/ --fix",
    "dev:nodered": "node tests/launcher/launch.js",
    "docker:e2e:up": "docker compose -f tests/e2e/docker-compose.yml up -d",
    "docker:e2e:down": "docker compose -f tests/e2e/docker-compose.yml down -v",
    "docker:e2e:logs": "docker compose -f tests/e2e/docker-compose.yml logs -f",
    "test:e2e": "node tests/e2e/run-e2e-tests.js",
    "test:integration": "node tests/e2e/oauth2-integration.test.js",
    "test:opa": "node tests/e2e/opa-integration.test.js",
    "setup:certs": "bash tests/e2e/setup-certs.sh",
    "test:openapi-tls": "node tests/e2e/openapi-tls.test.js"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "mocha": "^10.4.0",
    "node-red": "^4.1.1",
    "node-red-node-test-helper": "^0.3.5",
    "should": "^13.2.3",
    "sinon": "^17.0.0"
  },
  "node-red": {
    "version": ">=2.0.0",
    "nodes": {
      "api-config": "nodes/api-config.js",
      "api-server": "nodes/api-server.js",
      "api-endpoint": "nodes/api-endpoint.js"
    },
    "resources": "resources"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "jsonata": "^2.0.6",
    "mssql": "^12.2.0",
    "pino": "^9.0.0",
    "prom-client": "^15.1.3"
  },
  "optionalDependencies": {
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "fastify": "^5.6.2",
    "js-yaml": "^4.1.0",
    "pino-pretty": "^11.0.0"
  }
}
