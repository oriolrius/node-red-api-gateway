        "z": "openapi-tls-flow",
        "name": "Handle Echo",
        "func": "// Echo the message back with metadata\nconst body = msg.req.body;\n\nmsg.res.json({\n    echo: body.message,\n    receivedAt: new Date().toISOString(),\n    protocol: 'https'\n});\n\nreturn null;",
