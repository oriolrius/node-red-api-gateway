# API Gateway Development Stack Environment Configuration
# Copy this file to .env and customize as needed
#
# Usage:
#   cp .env.example .env
#   docker compose up -d

# ============================================================================
# Keycloak Configuration
# ============================================================================

# Admin console credentials
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Realm configuration
KEYCLOAK_REALM=api-gateway
KEYCLOAK_CLIENT_ID=api-gateway-client
KEYCLOAK_CLIENT_SECRET=api-gateway-secret

# ============================================================================
# OPA Configuration
# ============================================================================

# OPA log level (debug, info, warn, error)
OPA_LOG_LEVEL=info

# Optional: OPA authentication token (for production)
# OPA_AUTH_TOKEN=your-secure-token

# ============================================================================
# SQL Server Configuration (only used with --profile sqlserver)
# ============================================================================

# SA password (must meet complexity requirements)
# SECURITY: Change this in production!
SA_PASSWORD=DevPassword123!

# Database for the API Gateway
SQLSERVER_DATABASE=ApiGateway

# ============================================================================
# Node-RED Configuration (only used with --profile nodered)
# ============================================================================

# Node-RED admin credentials (optional)
# NODE_RED_CREDENTIAL_SECRET=your-credential-secret

# Timezone
TZ=UTC

# ============================================================================
# Network Configuration
# ============================================================================

# Port mappings (change if you have conflicts)
# Note: These are exposed from the network-base container
KEYCLOAK_PORT=8080
OPA_PORT=8181
SQLSERVER_PORT=1433
NODERED_PORT=1880
